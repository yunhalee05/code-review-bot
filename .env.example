# GitLab
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=your-gitlab-private-token
GITLAB_PROJECT_ID=12345

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Review Settings
REVIEW_PROVIDER=claude              # "claude" 또는 "openai"
REVIEW_MODEL=claude-sonnet-4-20250514    # Claude 사용 시 모델
OPENAI_REVIEW_MODEL=gpt-4o              # OpenAI 사용 시 모델
MAX_HUNKS_PER_FILE=20
MAX_FILES_PER_MR=30
LOG_LEVEL=INFO
